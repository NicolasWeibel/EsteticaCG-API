# =========================
# .env.example
# =========================
#
# Esta plantilla es solo de referencia.
# El proyecto carga .env.<ENV>, por ejemplo:
# - .env.staging
# - .env.production
#
# Uso recomendado:
# 1. Copia este archivo a .env.staging o .env.production
# 2. Reemplaza todos los placeholders
# 3. No subas archivos .env reales con secretos
#
# Notas de formato:
# - Las listas tipo env.list usan comas: a,b,c
# - Las listas de regex o prefixes usan punto y coma: a;b;c

# ── Core ──
# Nombre lógico del entorno. Debe coincidir con el nombre del archivo .env.<ENV>
ENV=staging

# 0 para entornos remotos; 1 solo para desarrollo local
DEBUG=0

# Clave secreta de Django. Genera una distinta por entorno.
SECRET_KEY=replace-with-a-long-random-secret

# django.contrib.sites / allauth
SITE_ID=1

# Zona horaria principal de la app
TIME_ZONE=America/Argentina/Buenos_Aires

# Titulo de la documentacion OpenAPI/Swagger
OPENAPI_TITLE=EsteticaCG API


# ── Hosts y Frontend ──
# Hosts permitidos para Django. Usa .run.app mientras no tengas dominio.
ALLOWED_HOSTS=.run.app

# Frontends que pueden consumir la API con credenciales/cookies.
# Separados por coma.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://frontend.example.com,https://admin.example.com

# Regex opcionales para frontends dinamicos. Separados por ;
CORS_ALLOWED_ORIGIN_REGEXES=

# Origins confiables para CSRF. Normalmente coinciden con los del frontend.
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://frontend.example.com,https://admin.example.com

# Regex opcionales para CSRF. Separados por ;
CSRF_TRUSTED_ORIGIN_REGEXES=

# Cookies JWT de tu autenticacion propia
AUTH_COOKIE_SECURE=1
AUTH_COOKIE_SAMESITE=None
AUTH_COOKIE_DOMAIN=

# Overrides opcionales de cookies
# AUTH_COOKIE_ACCESS_NAME=accessToken
# AUTH_COOKIE_REFRESH_NAME=refreshToken
# AUTH_COOKIE_PATH=/

# Solo cambia esto si necesitas forzar la politica SameSite de cookies de sesion/CSRF
# SESSION_COOKIE_SAMESITE=None
# CSRF_COOKIE_SAMESITE=None

# URL a la que redirige el login Google si no mandas ?next=
FRONTEND_LOGIN_REDIRECT_URL=https://admin.example.com/login

# URLs exactas permitidas para volver despues del login/logout
ACCOUNT_ALLOWED_REDIRECT_URLS=https://frontend.example.com/mi-cuenta,https://frontend.example.com/auth/callback,https://admin.example.com/login,https://admin.example.com/auth/callback

# Regex opcionales para redirects. Separados por ;
ACCOUNT_ALLOWED_REDIRECT_URL_REGEXES=


# ── Database ──
# Connection string de Postgres/Supabase. Para Supabase pooler usa sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require

# Recomendado con pooler/pgBouncer
CONN_MAX_AGE=60
DISABLE_SERVER_SIDE_CURSORS=1


# ── Proxy Secret ──
# Hace que Django use X-Forwarded-Host. Activalo solo detrás de un proxy confiable.
USE_X_FORWARDED_HOST=0

# Activalo solo si pones un proxy propio delante (por ejemplo Cloudflare Worker)
REQUIRE_PROXY_SECRET=0

# Shared secret esperado por el middleware cuando REQUIRE_PROXY_SECRET=1
PROXY_SHARED_SECRET=

# Prefijos de ruta exentos del proxy secret. Separados por ;
PROXY_SECRET_EXEMPT_PATH_PREFIXES=/healthz;/accounts/;/api/v1/auth/google/


# ── Cache / Redis ──
# Si no usas Redis, dejalo vacio y Django usara cache local en memoria.
REDIS_URL=

# Prefijo opcional de claves si usas Redis
CACHE_KEY_PREFIX=core


# ── Celery ──
# Si usas Redis como broker, puedes apuntar al mismo REDIS_URL o a otro.
# Si no defines nada, el proyecto cae a memoria/local, util para desarrollo.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=cache+memory://
CELERY_TASK_IGNORE_RESULT=1

# En staging puede servir 1 para simplificar. En production deberia ser 0 si agregas worker.
CELERY_TASK_ALWAYS_EAGER=1

# Mantiene trazas completas cuando una tarea eager falla.
CELERY_TASK_EAGER_PROPAGATES=1


# ── Email ──
# En desarrollo local puedes usar console.EmailBackend.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=replace-with-smtp-user
EMAIL_HOST_PASSWORD=replace-with-smtp-password
EMAIL_FROM_NAME=EsteticaCG
DEFAULT_FROM_EMAIL=no-reply@example.com


# ── Google OAuth / allauth ──
# Se usan para poblar/actualizar la SocialApp con el comando add_google_app.
# Si no usas login con Google, puedes dejarlos vacios.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── Sentry ──
# Opcional
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_ENABLE_TRACING=0


# ── Cloudinary ──
# Credenciales de la cuenta de Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Tipo de recurso; normalmente no hace falta tocarlo
CLOUDINARY_RESOURCE_TYPE=auto

# Prefijo/carpeta base para separar assets por entorno
# Ejemplos:
# - estetica-staging
# - estetica-production
CLOUDINARY_FOLDER=estetica-staging


# ── Reviews ──
# Provider publico de reviews. "manual" usa solo las reviews guardadas localmente.
# "google" habilita integracion con Google Business Profile.
REVIEWS_PROVIDER=manual
REVIEWS_FALLBACK_TO_MANUAL=1
REVIEWS_DEFAULT_MIN_RATING=4
REVIEWS_DEFAULT_WITH_CONTENT=1
REVIEWS_PUBLIC_LIMIT=10
REVIEWS_CACHE_DAYS=7
REVIEWS_CACHE_REFRESH_HOURS=24
REVIEWS_GOOGLE_AUTO_SYNC_ON_READ=1

# Solo completar si REVIEWS_PROVIDER=google
REVIEWS_GOOGLE_ACCOUNT_ID=
REVIEWS_GOOGLE_LOCATION_ID=
REVIEWS_GOOGLE_ACCESS_TOKEN=
REVIEWS_GOOGLE_REFRESH_TOKEN=
REVIEWS_GOOGLE_CLIENT_ID=
REVIEWS_GOOGLE_CLIENT_SECRET=
